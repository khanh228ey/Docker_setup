FROM node:20-alpine

WORKDIR /app

# Copy package files and install deps once during image build
COPY ../react_service/package*.json ./
RUN npm ci --legacy-peer-deps && npm cache clean --force

# Copy source code
COPY ../react_service /app

EXPOSE 3001
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3001"]